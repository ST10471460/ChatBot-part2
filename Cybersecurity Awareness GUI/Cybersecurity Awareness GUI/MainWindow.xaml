<!--
  MainWindow.xaml
  Purpose: Main UI for the CyberBot application. Contains three phases:
    1) ASCII wall animation (AnimationPhase)
    2) Bot greeting and name input (GreetingPhase)
    3) Main interaction UI with bot art, responses and topic menu (MainPhase)

  Important named elements referenced in code-behind:
    - AsciiOutput, BotArtGreeting, GreetingMessage, NameInput
    - AnimationPhase, GreetingPhase, MainPhase
    - BotArtMain, HeaderLabel, BotResponse, AskPanel, UserInput
    - Buttons wired to event handlers: NameSubmit_Click, AskBot_Click, Password_Click,
      Phishing_Click, Browsing_Click, Send_Click, Exit_Click
-->
<Window x:Class="Cybersecurity_Awareness_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cybersecurity_Awareness_GUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        Background="{DynamicResource Dark}"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded">

    <Window.Resources>
        <!-- purple colour palette -->
        <!-- Claude was used here to get a colour palete-->
        <SolidColorBrush x:Key="Accent"    Color="#A855F7"/>
        <SolidColorBrush x:Key="AccentDeep" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentDim" Color="#6D28D9"/>
        <SolidColorBrush x:Key="Dark"      Color="#0B0810"/>
        <SolidColorBrush x:Key="Panel"     Color="#110D1A"/>
        <SolidColorBrush x:Key="Card"     Color="#160E24"/>
        <SolidColorBrush x:Key="BorderCol"    Color="#2D1B4E"/>
        <SolidColorBrush x:Key="TextMain"  Color="#E2D4F5"/>
        <SolidColorBrush x:Key="TextDim"   Color="#6B4FA0"/>

        <!-- Monospaced font used everywhere -->
        <FontFamily x:Key="Mono">Consolas</FontFamily>

        <!-- Standard menu button style -->
        <Style x:Key="CyberBtn" TargetType="Button">
            <Setter Property="FontFamily"         Value="{StaticResource Mono}"/>
            <Setter Property="FontSize"           Value="13"/>
            <Setter Property="FontWeight"         Value="Bold"/>
            <Setter Property="Foreground"         Value="{StaticResource Accent}"/>
            <Setter Property="Background"         Value="#0F1923"/>
            <Setter Property="BorderBrush"        Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Padding"            Value="0,10"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"   Value="#2D1B4E"/>
                                <Setter Property="Foreground"   Value="#E2D4F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3B1F6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exit button red color palette  -->
        <Style x:Key="ExitBtn" TargetType="Button" BasedOn="{StaticResource CyberBtn}">
            <Setter Property="Foreground"   Value="#F87171"/>
            <Setter Property="BorderBrush"  Value="#7F1D1D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#3B0D0D"/>
                    <Setter Property="Foreground"  Value="#FCA5A5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── TextBox ── -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="FontFamily"      Value="{StaticResource Mono}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Background"      Value="#160E24"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Accent}"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentDim}"/>
        </Style>
    </Window.Resources>

    <!-- grid -->
    <Grid>

        <!-- ASCII WALL ANIMATION-->
        <Grid x:Name="AnimationPhase" Background="#0B0810" Panel.ZIndex="10">
            <TextBlock x:Name="AsciiOutput"
                       FontFamily="{StaticResource Mono}"
                       FontSize="11"
                       Foreground="#3B1F6A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
        </Grid>

        <!-- bot art and intro -->
        <Grid x:Name="GreetingPhase" Visibility="Collapsed" Background="#0B0810" Panel.ZIndex="9">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="480">

                <TextBlock x:Name="BotArtGreeting"
                           FontFamily="{StaticResource Mono}"
                           FontSize="13"
                           Foreground="{StaticResource Accent}"
                           HorizontalAlignment="Center"
                           TextAlignment="Left"
                           xml:space="preserve"/>

                <TextBlock Text="─────────────────────────────────"
                           FontFamily="{StaticResource Mono}"
                           Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,10"/>

                <!-- Bot greeting message -->
                <TextBlock x:Name="GreetingMessage"
                           FontFamily="{StaticResource Mono}"
                           FontSize="13"
                           Foreground="{StaticResource TextMain}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Input row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NameInput"
                             Grid.Column="0"
                             FontFamily="{StaticResource Mono}"
                             FontSize="13"
                             Foreground="{StaticResource Accent}"
                             Background="#0F1923"
                             BorderBrush="{StaticResource Accent}"
                             BorderThickness="1"
                             CaretBrush="{StaticResource Accent}"
                             Padding="8,6"
                             Margin="0,0,8,0"
                             KeyDown="NameInput_KeyDown"/>
                    <Button Grid.Column="1"
                            Content="ENTER"
                            Style="{StaticResource CyberBtn}"
                            Click="NameSubmit_Click"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Main UI-->
        <Grid x:Name="MainPhase" Visibility="Collapsed" Panel.ZIndex="8">

            <!-- co-pilot was used here -->
            <!-- Subtle scanline overlay -->
            <Rectangle IsHitTestVisible="False" Opacity="0.03">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,1,4"
                                  ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#A855F7">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,1,1"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Outer padding -->
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <!-- Left: bot art + response panel -->
                    <ColumnDefinition Width="340"/>
                    <!-- Right: menu buttons -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left side -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- header bar -->
                        <RowDefinition Height="Auto"/>
                        <!-- bot art -->
                        <RowDefinition Height="*"/>
                        <!-- response area -->
                        <RowDefinition Height="Auto"/>
                        <!-- ask-input row -->
                    </Grid.RowDefinitions>

                    <!-- Header bar -->
                    <Border Grid.Row="0"
                            Background="#110D1A"
                            BorderBrush="{StaticResource Accent}"
                            BorderThickness="1,1,1,0"
                            Padding="12,6">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource Accent}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HeaderLabel"
                                       FontFamily="{StaticResource Mono}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDim}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Bot art -->
                    <Border Grid.Row="1"
                            Background="#0E0919"
                            BorderBrush="{StaticResource Accent}"
                            BorderThickness="1,0,1,0"
                            Padding="16,10">
                        <TextBlock x:Name="BotArtMain"
                                   FontFamily="{StaticResource Mono}"
                                   FontSize="12"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Chat log -->
                    <Border Grid.Row="2"
                            Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Accent}"
                            BorderThickness="1,1,1,0"
                            Margin="0,8,0,0">
                        <ScrollViewer x:Name="ChatScroller"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="8,6">
                            <StackPanel x:Name="ChatLog"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Response area -->
                    <Border Grid.Row="2"
                            Background="{StaticResource Panel}"
                            BorderBrush="{StaticResource Accent}"
                            BorderThickness="1,1,1,0"
                            Margin="0,10,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="14,12">
                            <TextBlock x:Name="BotResponse"
                                       FontFamily="{StaticResource Mono}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMain}"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Ask-input row (hidden until Ask button used) -->
                    <Grid Grid.Row="3" x:Name="AskPanel" Visibility="Collapsed" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserInput"
                                 Grid.Column="0"
                                 FontFamily="{StaticResource Mono}"
                                 FontSize="12"
                                 Foreground="{StaticResource Accent}"
                                 Background="#0F1923"
                                 BorderBrush="{StaticResource Accent}"
                                 BorderThickness="1"
                                 CaretBrush="{StaticResource Accent}"
                                 Padding="8,6"
                                 Margin="0,0,6,0"
                                 KeyDown="UserInput_KeyDown"/>
                        <Button Grid.Column="1"
                                Content="SEND"
                                Style="{StaticResource CyberBtn}"
                                Click="Send_Click"/>
                    </Grid>
                </Grid>

                <!-- right side and menu -->
                <Grid Grid.Column="1" Margin="18,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- title -->
                        <RowDefinition Height="*"/>
                        <!-- buttons -->
                    </Grid.RowDefinitions>

                    <!-- Section title -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource TextDim}"
                            BorderThickness="0,0,0,1"
                            Margin="0,0,0,18">
                        <TextBlock Text="MENU"
                                   FontFamily="{StaticResource Mono}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDim}"
                                   Margin="0,0,0,6"/>
                    </Border>

                    <!-- Button stack -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top">

                        <!-- Ask a question -->
                        <Border Background="#0F1923"
                                BorderBrush="#1A2E20"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="14,12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ASK CYBERBOT"
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Type any cybersecurity question and get an instant answer."
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <Button Content="[ OPEN INPUT ]"
                                        Style="{StaticResource CyberBtn}"
                                        HorizontalAlignment="Stretch"
                                        Click="AskBot_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Passwords -->
                        <Border Background="#0F1923"
                                BorderBrush="#1A2E20"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="14,12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="PASSWORDS &amp; AUTH"
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Strong passwords, passphrases, 2FA and password managers."
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <Button Content="[ LEARN MORE ]"
                                        Style="{StaticResource CyberBtn}"
                                        HorizontalAlignment="Stretch"
                                        Click="Password_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Phishing -->
                        <Border Background="#0F1923"
                                BorderBrush="#1A2E20"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="14,12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="PHISHING &amp; SCAMS"
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Spot fake emails, social engineering and targeted attacks."
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <Button Content="[ LEARN MORE ]"
                                        Style="{StaticResource CyberBtn}"
                                        HorizontalAlignment="Stretch"
                                        Click="Phishing_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Safe Browsing -->
                        <Border Background="#0F1923"
                                BorderBrush="#1A2E20"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="14,12"
                                Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="SAFE BROWSING"
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="HTTPS, VPNs, public Wi-Fi risks and safe download habits."
                                           FontFamily="{StaticResource Mono}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>
                                <Button Content="[ LEARN MORE ]"
                                        Style="{StaticResource CyberBtn}"
                                        HorizontalAlignment="Stretch"
                                        Click="Browsing_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Exit -->
                        <Button Content="[ EXIT SESSION ]"
                                Style="{StaticResource ExitBtn}"
                                HorizontalAlignment="Stretch"
                                Padding="0,12"
                                Click="Exit_Click"/>

                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>

    </Grid>
</Window>